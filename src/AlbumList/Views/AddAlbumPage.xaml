<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlbumList.ViewModels"
             x:Class="AlbumList.Views.AddAlbumPage"
             x:DataType="vm:AddAlbumViewModel"
             Title="Add Album">

    <VerticalStackLayout Padding="16" Spacing="12">

        <Label Text="Album Name" />
        <Entry Text="{Binding Name}" Placeholder="Enter album name" />

        <Label Text="Artist" />
        <Entry Text="{Binding Artist}" Placeholder="Enter artist name" />

        <Button Text="Save" Command="{Binding SaveCommand}" />

    </VerticalStackLayout>

</ContentPage>
